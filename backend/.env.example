# ── Required ──────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-secret

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/detaildash

# SQLite is used automatically when DATABASE_URL is not set (development only)

# ── Flask ─────────────────────────────────────────────────────────
FLASK_ENV=production
# Set to 1 only in development
FLASK_DEBUG=0

# ── Optional ──────────────────────────────────────────────────────
# Base URL of the application (used in emails / links if added later)
APP_URL=https://yourdomain.com
